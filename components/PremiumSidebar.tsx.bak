'use client';

import { useState } from 'react';
import Link from 'next/link';
import { usePathname } from 'next/navigation';
import { Button, Avatar, Badge } from './PremiumUI';
import PremiumIcons from './PremiumIcons';

interface NavItem {
  label: string;
  icon?: React.ReactNode;
  href: string;
  badge?: number;
  children?: NavItem[];
}

export default function PremiumSidebar() {
  const pathname = usePathname();
  const [isCollapsed, setIsCollapsed] = useState(false);
  const [expandedItems, setExpandedItems] = useState<string[]>([]);
  
  const navItems: NavItem[] = [
    {
      label: 'Dashboard',
      icon: <PremiumIcons.Layout className="w-5 h-5" />,
      href: '/admin/dashboard'
    },
    {
      label: 'Leads',
      icon: <PremiumIcons.Users className="w-5 h-5" />,
      href: '/admin/leads',
      badge: 23
    },
    {
      label: 'Conteúdo AI',
      icon: <PremiumIcons.Cpu className="w-5 h-5" />,
      href: '/admin/ia-content',
      badge: 15
    },
    {
      label: 'Projetos',
      icon: <PremiumIcons.Folder className="w-5 h-5" />,
      href: '/admin/projects',
      children: [
        { label: 'Todos Projetos', href: '/admin/projects' },
        { label: 'Em Progresso', href: '/admin/projects?status=in_progress' },
        { label: 'Concluídos', href: '/admin/projects?status=completed' },
        { label: 'Portfólio', href: '/admin/portfolio' }
      ]
    },
    {
      label: 'Financeiro',
      icon: <PremiumIcons.Coins className="w-5 h-5" />,
      href: '/admin/financeiro',
      children: [
        { label: 'Transações', href: '/admin/financeiro' },
        { label: 'Assinaturas', href: '/admin/assinaturas' },
        { label: 'Relatórios', href: '/admin/relatorios' }
      ]
    },
    {
      label: 'Marketing',
      icon: <PremiumIcons.ChartBar className="w-5 h-5" />,
      href: '/admin/marketing',
      children: [
        { label: 'Campanhas', href: '/admin/marketing' },
        { label: 'Analytics', href: '/admin/analytics' },
        { label: 'Blog', href: '/admin/blog' },
        { label: 'Cupons', href: '/admin/cupons' }
      ]
    },
    {
      label: 'Configurações',
      icon: <PremiumIcons.Settings className="w-5 h-5" />,
      href: '/admin/settings',
      children: [
        { label: 'Geral', href: '/admin/settings' },
        { label: 'Integrações', href: '/admin/integrations' },
        { label: 'API Keys', href: '/admin/api-keys' },
        { label: 'Usuários', href: '/admin/users' }
      ]
    }
  ];
  
  const toggleItem = (label: string) => {
    setExpandedItems(prev =>
      prev.includes(label)
        ? prev.filter(item => item !== label)
        : [...prev, label]
    );
  };
  
  const isActive = (href: string) => {
    return pathname === href || pathname?.startsWith(href + '/');
  };
  
  return (
    <div className={`flex flex-col h-screen bg-gradient-to-b from-[#0A0A0A] to-black border-r border-white/10 transition-all duration-300 ${
      isCollapsed ? 'w-20' : 'w-64'
    }`}>
      {/* Logo */}
      <div className="p-6 border-b border-white/10">
        <div className="flex items-center justify-between">
          {!isCollapsed && (
            <div className="flex items-center gap-3">
              <div className="w-8 h-8 bg-gradient-to-r from-[#00D4FF] to-[#7B2CBF] rounded-lg"></div>
              <div>
                <div className="font-bold text-lg">ESTUDIOK</div>
                <div className="text-xs text-gray-400">Premium</div>
              </div>
            </div>
          )}
          
          <button
            onClick={() => setIsCollapsed(!isCollapsed)}
            className="p-2 hover:bg-white/5 rounded-lg transition-colors"
          >
            {isCollapsed ? (
              <PremiumIcons.ChevronRight className="w-5 h-5" />
            ) : (
              <PremiumIcons.ChevronLeft className="w-5 h-5" />
            )}
          </button>
        </div>
      </div>
      
      {/* User Profile */}
      {!isCollapsed && (
        <div className="p-4 border-b border-white/10">
          <div className="flex items-center gap-3">
            <Avatar 
              name="Admin User" 
              size="md" 
              status="online"
            />
            <div className="flex-1">
              <div className="font-semibold">Admin User</div>
              <div className="text-sm text-gray-400">Administrador</div>
            </div>
            <Badge variant="premium">PRO</Badge>
          </div>
        </div>
      )}
      
      {/* Navigation */}
      <nav className="flex-1 p-4 space-y-1 overflow-y-auto">
        {navItems.map((item) => {
          const active = isActive(item.href);
          const expanded = expandedItems.includes(item.label);
          
          if (isCollapsed) {
            return (
              <Link
                key={item.label}
                href={item.href}
                className={`flex items-center justify-center p-3 rounded-lg transition-colors relative ${
                  active 
                    ? 'bg-gradient-to-r from-[#00D4FF]/20 to-[#7B2CBF]/20 text-[#00D4FF]' 
                    : 'text-gray-400 hover:text-white hover:bg-white/5'
                }`}
                title={item.label}
              >
                <div className="relative">
                  {item.icon}
                  {item.badge && (
                    <div className="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-xs rounded-full flex items-center justify-center">
                      {item.badge > 9 ? '9+' : item.badge}
                    </div>
                  )}
                </div>
              </Link>
            );
          }
          
          return (
            <div key={item.label}>
              <div
                onClick={() => item.children ? toggleItem(item.label) : undefined}
                className={`flex items-center justify-between p-3 rounded-lg cursor-pointer transition-colors ${
                  active 
                    ? 'bg-gradient-to-r from-[#00D4FF]/20 to-[#7B2CBF]/20 text-[#00D4FF]' 
                    : 'text-gray-400 hover:text-white hover:bg-white/5'
                }`}
              >
                <Link href={item.children ? '#' : item.href} className="flex items-center gap-3 flex-1">
                  {item.icon}
                  <span>{item.label}</span>
                </Link>
                
                <div className="flex items-center gap-2">
                  {item.badge && (
                    <Badge variant="error">{item.badge}</Badge>
                  )}
                  
                  {item.children && (
                    <PremiumIcons.ChevronRight className={`w-4 h-4 transition-transform ${expanded ? 'rotate-90' : ''}`} />
                  )}
                </div>
              </div>
              
              {item.children && expanded && (
                <div className="ml-8 mt-1 space-y-1">
                  {item.children.map((child) => (
                    <Link
                      key={child.href}
                      href={child.href}
                      className={`block py-2 px-4 rounded text-sm transition-colors ${
                        isActive(child.href)
                          ? 'text-[#00D4FF] bg-[#00D4FF]/10'
                          : 'text-gray-400 hover:text-white hover:bg-white/5'
                      }`}
                    >
                      {child.label}
                    </Link>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </nav>
      
      {/* Bottom Actions */}
      <div className="p-4 border-t border-white/10">
        {!isCollapsed ? (
          <div className="space-y-3">
            <Button variant="primary" fullWidth icon={<PremiumIcons.Plus className="w-5 h-5" />}>
              Novo Projeto
            </Button>
            
            <div className="text-center text-xs text-gray-500">
              <div>ESTUDIOK Premium</div>
              <div>v2.0 • © 2026</div>
            </div>
          </div>
        ) : (
          <div className="flex justify-center">
            <Button variant="primary" icon={<PremiumIcons.Plus className="w-5 h-5" />}>
              Novo
            </Button>
          </div>
        )}
      </div>
    </div>
  );
}
